# ==================== Spring Boot / Java Common ====================
# Compiled output directories
**/target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/     # Prevent ignoring target packages inside source code (rare case)
!**/src/test/**/target/

**/build/
!.gradle/                   # Keep Gradle wrapper
!**/src/main/**/build/
!**/src/test/**/build/

# Logs and temporary files
*.log
*.log.*
logs/
tmp/
temp/

# IDE and editor files (Very important!)
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
.springBeans
*.launch
*.tmp
*.bak

# Maven and Gradle Wrapper (Do not ignore wrapper files)
!.mvn/wrapper/
!gradle/wrapper/

# Operating system files
.DS_Store
Thumbs.db

# Environment and sensitive configuration files (Must be ignored!)
application-dev.yml
application-prod.yml
application-local.yml
*.env
config/application-*.yml    # If you put config files in a config directory

# Other common files to ignore
*.jar
*.war
*.class
*.cache
*.swp
*~
